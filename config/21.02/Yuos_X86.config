# ================================
# 型号
# ================================
# 型号
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 镜像大小
#
CONFIG_TARGET_KERNEL_PARTSIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_ROOTFS_PARTNAME=""


# ================================
# 基本包
# ================================
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libevent2=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libuv=y
CONFIG_PACKAGE_libwebsockets-full=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_redsocks2=y
CONFIG_PACKAGE_terminfo=y
CONFIG_PACKAGE_tcping=y


# ================================
# LuCI
# ================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-theme-bootstrap=y


# ================================
# LuCI 多语言（全部保留）
# ================================
CONFIG_LUCI_LANG_ar=y
CONFIG_LUCI_LANG_bg=y
CONFIG_LUCI_LANG_bn_BD=y
CONFIG_LUCI_LANG_ca=y
CONFIG_LUCI_LANG_cs=y
CONFIG_LUCI_LANG_da=y
CONFIG_LUCI_LANG_de=y
CONFIG_LUCI_LANG_el=y
CONFIG_LUCI_LANG_en=y
CONFIG_LUCI_LANG_es=y
CONFIG_LUCI_LANG_fi=y
CONFIG_LUCI_LANG_fr=y
CONFIG_LUCI_LANG_he=y
CONFIG_LUCI_LANG_hi=y
CONFIG_LUCI_LANG_hu=y
CONFIG_LUCI_LANG_it=y
CONFIG_LUCI_LANG_ja=y
CONFIG_LUCI_LANG_ko=y
CONFIG_LUCI_LANG_mr=y
CONFIG_LUCI_LANG_ms=y
CONFIG_LUCI_LANG_nb_NO=y
CONFIG_LUCI_LANG_nl=y
CONFIG_LUCI_LANG_pl=y
CONFIG_LUCI_LANG_pt=y
CONFIG_LUCI_LANG_pt_BR=y
CONFIG_LUCI_LANG_ro=y
CONFIG_LUCI_LANG_ru=y
CONFIG_LUCI_LANG_sk=y
CONFIG_LUCI_LANG_sv=y
CONFIG_LUCI_LANG_tr=y
CONFIG_LUCI_LANG_uk=y
CONFIG_LUCI_LANG_vi=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_LUCI_LANG_zh_Hant=y

# ================================
# kmod 基础模块
# ================================
CONFIG_PACKAGE_kmod-iptunnel=y
CONFIG_PACKAGE_kmod-iptunnel4=y
CONFIG_PACKAGE_kmod-slhc=y


# ================================
# 网络 Netfilter（保留常用）
# ================================
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-filter=y
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-socket=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y

CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nf-ipt=y
CONFIG_PACKAGE_kmod-nf-ipt6=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nf-reject=y
CONFIG_PACKAGE_kmod-nf-reject6=y
CONFIG_PACKAGE_kmod-nf-socket=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-nfnetlink=y

CONFIG_PACKAGE_libnfnetlink=y
CONFIG_PACKAGE_libnftnl=y


# ================================
# 删除的无用模块（注释说明）
# ================================

# IPVS负载均衡（路由器基本不用）
# CONFIG_PACKAGE_kmod-nf-ipvs is not set

# Netfilter日志
# CONFIG_PACKAGE_kmod-nf-log is not set
# CONFIG_PACKAGE_kmod-nf-log6 is not set

# iptables日志
# CONFIG_PACKAGE_kmod-ipt-nflog is not set
# CONFIG_PACKAGE_kmod-ipt-nfqueue is not set

# netfilter日志接口
# CONFIG_PACKAGE_kmod-nfnetlink-log is not set
# CONFIG_PACKAGE_kmod-nfnetlink-queue is not set

# ipsec支持（一般不用）
# CONFIG_PACKAGE_kmod-ipt-ipsec is not set

# HTTP/2库（除非使用nginx/aria2）
# CONFIG_PACKAGE_libnghttp2 is not set


# ================================
# LuCI 依赖
# ================================
CONFIG_PACKAGE_luci-compat=y

# ipkg兼容库（21.02基本不需要）
# CONFIG_PACKAGE_luci-lib-ipkg is not set

CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_swconfig=y
CONFIG_PACKAGE_kmod-swconfig=y
CONFIG_PACKAGE_default-settings=y


# ================================
# 自动重启
# ================================
CONFIG_PACKAGE_luci-app-autoreboot=y


# ================================
# DHCP
# ================================
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcp6c_ext_cer_id=0

# 使用 ipv6only 版本 odhcpd
# CONFIG_PACKAGE_odhcpd is not set
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_odhcpd_ipv6only_ext_cer_id=0


CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y

# DNSSEC占内存，可按需开启
CONFIG_PACKAGE_dnsmasq_full_dnssec=y

# 权威DNS服务器（一般不用）
# CONFIG_PACKAGE_dnsmasq_full_auth is not set

CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_conntrack=y
CONFIG_PACKAGE_dnsmasq_full_noid=y

# TFTP服务器（家庭环境基本不用）
# CONFIG_PACKAGE_dnsmasq_full_tftp is not set

CONFIG_PACKAGE_dropbear=y


# ================================
# IPV6
# ================================
CONFIG_IPV6=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_kmod-ebtables-ipv6=y


# ================================
# 接口支持
# ================================
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

# 硬件加速
CONFIG_PACKAGE_TURBOACC_INCLUDE_NO_FASTPATH=y
CONFIG_PACKAGE_luci-app-turboacc-mtk=y

# 插件
CONFIG_PACKAGE_luci-app-homeproxy=y

# DDNS-GO
CONFIG_PACKAGE_luci-app-ddns-go=y